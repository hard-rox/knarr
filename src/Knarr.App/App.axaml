<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Knarr.App.App"
             xmlns:local="using:Knarr.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows the system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Knarr.App/Themes/Glass.axaml"/>
                <ResourceInclude Source="avares://Knarr.App/Themes/Icons.axaml"/>
                <ResourceInclude Source="avares://Knarr.App/Controls/Pill.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!--
            Project-wide "liquid glass" shadow guideline.
            Elevation tokens ported from docs/mockups/knarr-ui-glass.html so every glass card,
            panel and toolbar button carries a consistent soft shadow. Buttons apply the shadow on
            their templated ContentPresenter (Button has no BoxShadow of its own); cards/panels use
            the Border.glass-card class.
        -->
        <Style Selector="Border.glass-card">
            <Setter Property="BoxShadow" Value="0 8 32 0 #2E1F2687" />
        </Style>

        <Style Selector="Button.primary /template/ ContentPresenter">
            <Setter Property="BoxShadow" Value="0 6 18 0 #660A84FF" />
        </Style>

        <Style Selector="Button.ghost /template/ ContentPresenter">
            <Setter Property="BoxShadow" Value="0 2 8 0 #1A1F2687" />
        </Style>

        <Style Selector="Button.danger /template/ ContentPresenter">
            <Setter Property="BoxShadow" Value="0 6 18 0 #59FF453A" />
        </Style>
    </Application.Styles>
</Application>
