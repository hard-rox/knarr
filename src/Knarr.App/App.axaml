<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Knarr.App.App"
             xmlns:local="using:Knarr.App"
             x:Name="Knarr"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows the system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Knarr.App/Themes/Glass.axaml"/>
                <ResourceInclude Source="avares://Knarr.App/Themes/Icons.axaml"/>
                <ResourceInclude Source="avares://Knarr.App/Controls/Pill.axaml"/>
                <ResourceInclude Source="avares://Knarr.App/Controls/Tile.axaml"/>
                <ResourceInclude Source="avares://Knarr.App/Controls/TerminalOutputView.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Knarr.App/Themes/Styles.axaml"/>
    </Application.Styles>
</Application>
