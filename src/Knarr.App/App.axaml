<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Knarr.App.App"
             xmlns:local="using:Knarr.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows the system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://Knarr.App/Themes/Glass.axaml"/>
                <ResourceInclude Source="avares://Knarr.App/Themes/Icons.axaml"/>
                <ResourceInclude Source="avares://Knarr.App/Controls/Pill.axaml"/>
                <ResourceInclude Source="avares://Knarr.App/Controls/Tile.axaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />

        <!--
            Project-wide "liquid glass" shadow guideline.
            Elevation tokens ported from docs/mockups/knarr-ui-glass.html so every glass card,
            panel and toolbar button carries a consistent soft shadow. Buttons apply the shadow on
            their templated ContentPresenter (Button has no BoxShadow of its own); cards/panels use
            the Border.glass-panel class.
        -->

        <!--
            Reusable frosted glass panel: the standard card surface (fill + stroke + soft shadow)
            used by feature toolbars and table containers. Views may still override CornerRadius.
        -->
        <Style Selector="Border.glass-panel">
            <Setter Property="Background" Value="{DynamicResource GlassFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BoxShadow" Value="0 8 32 0 #2E1F2687" />
        </Style>

        <!--
            Minimal icon button used for row actions and bulk actions across data tables.
            Transparent chrome with a subtle hover fill; icons render at 14x14.
        -->
        <Style Selector="Button.icon">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="5" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
        </Style>
        <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
        </Style>
        <Style Selector="Button.icon PathIcon">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
        </Style>

        <!--
            Disable the built-in row selection highlight for glass tables; selection is driven
            explicitly by a per-row checkbox, not by clicking the row.
        -->
        <Style Selector="TableViewRow:pointerover /template/ Border#Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TableViewRow:pressed /template/ Border#Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TableViewRow:selected /template/ Border#Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TableViewRow:selected:pointerover /template/ Border#Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="TableViewRow:selected:pressed /template/ Border#Border">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="Button.primary /template/ ContentPresenter">
            <Setter Property="BoxShadow" Value="0 6 18 0 #660A84FF" />
        </Style>

        <Style Selector="Button.ghost /template/ ContentPresenter">
            <Setter Property="BoxShadow" Value="0 2 8 0 #1A1F2687" />
        </Style>

        <Style Selector="Button.danger /template/ ContentPresenter">
            <Setter Property="BoxShadow" Value="0 6 18 0 #59FF453A" />
        </Style>

        <!--
            Liquid-glass search field. A pill-shaped, translucent input with a hairline stroke and a
            soft shadow that reads as a floating glass surface. The leading search glyph is supplied
            per-use via InnerLeftContent. Focus lifts the fill and switches the stroke to the accent.
        -->
        <Style Selector="TextBox.search">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="TextBox.search /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource GlassFillBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BoxShadow" Value="0 2 8 0 #1A1F2687" />
        </Style>
        <Style Selector="TextBox.search:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}" />
        </Style>
        <Style Selector="TextBox.search:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="{DynamicResource GlassStrongBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
    </Application.Styles>
</Application>
