<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!--
      Theme-variant aware palette for Knarr's "liquid glass" shell.
      Brushes are resolved via DynamicResource so they swap live when the
      requested theme variant changes (System / Light / Dark).
    -->

  <!-- Shared, theme-agnostic corner radius for Button/TextBox (matches the sidebar's expanded nav-item radius). -->
  <CornerRadius x:Key="ControlCornerRadius">12</CornerRadius>

  <ResourceDictionary.ThemeDictionaries>

    <ResourceDictionary x:Key="Light">
      <!-- Brand accent (reserved for primary emphasis / future primary buttons). -->
      <Color x:Key="AccentColor">#0A84FF</Color>
      <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

      <SolidColorBrush x:Key="TextBrush" Color="#1C1C22" />
      <SolidColorBrush x:Key="TextDimBrush" Color="#5B5F6B" />

      <LinearGradientBrush x:Key="BackgroundBaseBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Offset="0" Color="#FBC2EB" />
        <GradientStop Offset="0.55" Color="#A6C1EE" />
        <GradientStop Offset="1" Color="#84FAB0" />
      </LinearGradientBrush>

      <!-- Frosted glass surfaces layered on top of the acrylic backdrop -->
      <SolidColorBrush x:Key="GlassFillBrush" Color="#FFFFFF" Opacity="0.55" />
      <SolidColorBrush x:Key="GlassStrongBrush" Color="#FFFFFF" Opacity="0.72" />
      <SolidColorBrush x:Key="SidebarBrush" Color="#FFFFFF" Opacity="0.32" />
      <SolidColorBrush x:Key="StripBrush" Color="#FFFFFF" Opacity="0.28" />
      <SolidColorBrush x:Key="StrokeBrush" Color="#FFFFFF" Opacity="0.60" />
      <SolidColorBrush x:Key="HoverBrush" Color="#FFFFFF" Opacity="0.45" />
      <SolidColorBrush x:Key="IconButtonIdleBrush" Color="#FFFFFF" Opacity="0.24" />

      <!-- Accent-tinted glass for the primary CTA (Button.accent): translucent, not solid. -->
      <SolidColorBrush x:Key="AccentGlassBrush" Color="#0A84FF" Opacity="0.16" />
      <SolidColorBrush x:Key="AccentGlassHoverBrush" Color="#0A84FF" Opacity="0.24" />
      <SolidColorBrush x:Key="AccentStrokeBrush" Color="#0A84FF" Opacity="0.55" />
    </ResourceDictionary>

    <ResourceDictionary x:Key="Dark">
      <!-- Brand accent (reserved for primary emphasis / future primary buttons). -->
      <Color x:Key="AccentColor">#0A84FF</Color>
      <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />

      <SolidColorBrush x:Key="TextBrush" Color="#F5F6FA" />
      <SolidColorBrush x:Key="TextDimBrush" Color="#A0A4B0" />

      <LinearGradientBrush x:Key="BackgroundBaseBrush" StartPoint="0%,0%" EndPoint="100%,100%">
        <GradientStop Offset="0" Color="#1A0817" />
        <GradientStop Offset="0.55" Color="#080F1F" />
        <GradientStop Offset="1" Color="#05150D" />
      </LinearGradientBrush>

      <SolidColorBrush x:Key="GlassFillBrush" Color="#FFFFFF" Opacity="0.08" />
      <SolidColorBrush x:Key="GlassStrongBrush" Color="#FFFFFF" Opacity="0.14" />
      <SolidColorBrush x:Key="SidebarBrush" Color="#FFFFFF" Opacity="0.05" />
      <SolidColorBrush x:Key="StripBrush" Color="#FFFFFF" Opacity="0.04" />
      <SolidColorBrush x:Key="StrokeBrush" Color="#FFFFFF" Opacity="0.14" />
      <SolidColorBrush x:Key="HoverBrush" Color="#FFFFFF" Opacity="0.10" />
      <SolidColorBrush x:Key="IconButtonIdleBrush" Color="#FFFFFF" Opacity="0.06" />

      <!-- Accent-tinted glass for the primary CTA (Button.accent): translucent, not solid. -->
      <SolidColorBrush x:Key="AccentGlassBrush" Color="#0A84FF" Opacity="0.20" />
      <SolidColorBrush x:Key="AccentGlassHoverBrush" Color="#0A84FF" Opacity="0.30" />
      <SolidColorBrush x:Key="AccentStrokeBrush" Color="#0A84FF" Opacity="0.45" />
    </ResourceDictionary>

  </ResourceDictionary.ThemeDictionaries>

  <!--
      Shared "glass table" design.
      Theme-variant-agnostic resources reused by every feature that renders a data table
      (Containers, Images, Volumes, …). Reference the theme from a view with:

        <TableView Theme="{StaticResource GlassTableTheme}" ... />

      The two keyed resources below are picked up implicitly by all TableViews in the app:
      they hide the vertical header separators and align cell content with header content.
      Companion selectors (Button.icon, row-selection suppression) live in Themes/Styles.axaml.
    -->

  <!-- Remove the vertical separator lines drawn between header cells. -->
  <SolidColorBrush x:Key="TableViewColumnHeaderSeparatorBackground" Color="Transparent" />

  <!--
      Align cells with headers: rows wrap cells in a Border padded with TableViewRowPadding
      (default 6,9,6,12); the 6px left inset offsets cells right of the headers. Zero the
      horizontal part (keep vertical for row height) so both rely only on TableViewCellPadding (6,0).
    -->
  <Thickness x:Key="TableViewRowPadding">0,9,0,12</Thickness>

  <!-- Compact glass TableView theme: keeps the headers presenter but with a fixed-height, tinted header row. -->
  <ControlTheme x:Key="GlassTableTheme"
                TargetType="TableView"
                BasedOn="{StaticResource {x:Type TableView}}">
    <Setter Property="Template">
      <ControlTemplate>
        <Border ClipToBounds="{TemplateBinding ClipToBounds}"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <DockPanel>
            <TableViewColumnHeadersPresenter DockPanel.Dock="Top"
                                             Height="35"
                                             Background="{DynamicResource StripBrush}"
                                             ClipToBounds="True" />
            <ScrollViewer Name="PART_ScrollViewer"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <ItemsPresenter Name="PART_ItemsPresenter"
                              ItemsPanel="{TemplateBinding ItemsPanel}" />
            </ScrollViewer>
          </DockPanel>
        </Border>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
