<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Knarr.App.Features.Containers"
             xmlns:models="using:Knarr.App.Models"
             xmlns:controls="using:Knarr.App.Controls"
             x:Class="Knarr.App.Features.Containers.ContainersView"
             x:DataType="vm:ContainersViewModel">

  <Design.DataContext>
    <vm:ContainersViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,Auto,*" Margin="24" RowSpacing="16">

    <!-- Stat tiles -->
    <Grid Grid.Row="0" ColumnDefinitions="*,*,*" ColumnSpacing="16">
      <controls:Tile Grid.Column="0"
                     Label="Total containers"
                     Value="{Binding TotalCount, StringFormat='{}{0}'}" />
      <controls:Tile Grid.Column="1"
                     Label="Running"
                     Status="Running"
                     Value="{Binding RunningCount, StringFormat='{}{0}'}" />
      <controls:Tile Grid.Column="2"
                     Label="Stopped"
                     Status="Stopped"
                     Value="{Binding StoppedCount, StringFormat='{}{0}'}" />
    </Grid>

    <!-- Action bar: search (always) + toolbar / bulk actions -->
    <Border Grid.Row="1"
            Classes="glass-panel"
            Padding="14,10">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">

        <!-- Search -->
        <TextBox Grid.Column="0"
                 Classes="search"
                 Width="280"
                 VerticalAlignment="Center"
                 PlaceholderText="Search containers&#x2026;"
                 Text="{Binding SearchText}">
          <TextBox.InnerLeftContent>
            <PathIcon Data="{StaticResource SearchRegular}"
                      Width="14" Height="14"
                      Margin="6,0,2,0"
                      Foreground="{DynamicResource TextDimBrush}" />
          </TextBox.InnerLeftContent>
        </TextBox>

        <!-- Selection count -->
        <TextBlock Grid.Column="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextDimBrush}"
                   IsVisible="{Binding HasSelection}"
                   Text="{Binding SelectedCount, StringFormat='{}{0} selected'}" />

        <!-- Default toolbar OR bulk actions when rows are selected -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="2"
                    IsVisible="{Binding !HasSelection}">
          <Button Classes="icon"
                  ToolTip.Tip="Refresh"
                  Command="{Binding RefreshCommand}">
            <PathIcon Data="{StaticResource ArrowClockwiseRegular}" />
          </Button>
          <Button Classes="icon"
                  ToolTip.Tip="Run container"
                  Command="{Binding RunContainerCommand}">
            <PathIcon Data="{StaticResource PlayRegular}" />
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="2"
                    IsVisible="{Binding HasSelection}">
          <Button Classes="icon"
                  ToolTip.Tip="Start selected"
                  Command="{Binding StartSelectedCommand}">
            <PathIcon Data="{StaticResource PlayRegular}" />
          </Button>
          <Button Classes="icon"
                  ToolTip.Tip="Stop selected"
                  Command="{Binding StopSelectedCommand}">
            <PathIcon Data="{StaticResource StopRegular}" />
          </Button>
          <Button Classes="icon"
                  ToolTip.Tip="Delete selected"
                  Command="{Binding DeleteSelectedCommand}">
            <PathIcon Data="{StaticResource DeleteRegular}" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Glass panel hosting the table -->
    <Border Grid.Row="2"
            VerticalAlignment="Top"
            Classes="glass-panel"
            CornerRadius="16"
            ClipToBounds="True">
      <Grid>
        <TableView ItemsSource="{Binding Containers}"
                 Theme="{StaticResource GlassTableTheme}"
                 Background="Transparent"
                 BorderThickness="0"
                 IsVisible="{Binding HasItems}"
                 CanUserResizeColumns="False">
        <TableView.Columns>

          <!-- Select -->
          <TableViewColumn Width="48" HorizontalContentAlignment="Center">
            <TableViewColumn.Header>
              <CheckBox IsThreeState="True" HorizontalContentAlignment="Center"
                        IsChecked="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).AllSelected, Mode=TwoWay}" />
            </TableViewColumn.Header>
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" />
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Name + Container ID (selectable text) -->
          <TableViewColumn Header="Name" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <SelectableTextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" />
                  <SelectableTextBlock Text="{Binding ShortId}"
                                       FontFamily="Cascadia Code,Consolas,monospace"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextDimBrush}" />
                </StackPanel>
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Image (selectable text) -->
          <TableViewColumn Header="Image" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <SelectableTextBlock Text="{Binding Image}"
                                     VerticalAlignment="Center"
                                     FontFamily="Cascadia Code,Consolas,monospace"
                                     Foreground="{DynamicResource TextDimBrush}" />
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Status + Uptime -->
          <TableViewColumn Header="Status" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <controls:Pill Text="{Binding StatusText}" Status="{Binding PillStatus}" />
                  <TextBlock Text="{Binding Uptime}"
                             FontSize="11"
                             Foreground="{DynamicResource TextDimBrush}" />
                </StackPanel>
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Ports -->
          <TableViewColumn Header="Ports" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <TextBlock Text="{Binding Ports}"
                           VerticalAlignment="Center"
                           FontFamily="Cascadia Code,Consolas,monospace"
                           Foreground="{DynamicResource TextDimBrush}" />
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Actions (fixed width so it never shrinks) -->
          <TableViewColumn Header="Actions" Width="120" HorizontalContentAlignment="Left">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                  <Button Classes="icon"
                          ToolTip.Tip="Logs"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).LogsCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource TextBulletListRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Exec"
                          IsVisible="{Binding IsRunning}"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).ExecCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource CodeRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Stop"
                          IsVisible="{Binding IsRunning}"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).StopCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource StopRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Start"
                          IsVisible="{Binding !IsRunning}"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).StartCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource PlayRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Inspect"
                          IsVisible="{Binding !IsRunning}"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).InspectCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource InfoRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Remove"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).RemoveCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource DeleteRegular}" />
                  </Button>
                </StackPanel>
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>
        </TableView.Columns>
      </TableView>

      <!-- Loading state -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="14"
                  MinHeight="200"
                  IsVisible="{Binding IsLoading}">
        <ProgressBar Width="180"
                     Margin="0,12,0,0"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentBrush}" />
        <TextBlock Text="Loading containers&#x2026;"
                   HorizontalAlignment="Center"
                   FontSize="13"
                   Foreground="{DynamicResource TextDimBrush}" />
      </StackPanel>

      <!-- Empty state (no containers at all) -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="10"
                  MinHeight="200"
                  MaxWidth="360"
                  IsVisible="{Binding IsEmpty}">
        <PathIcon Data="{StaticResource CubeRegular}"
                  Width="40" Height="40"
                  Foreground="{DynamicResource TextDimBrush}" />
        <TextBlock Text="No containers yet"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <TextBlock Text="Run a container from an image to see it listed here."
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Foreground="{DynamicResource TextDimBrush}" />
        <Button Content="Run container"
                HorizontalAlignment="Center"
                Margin="0,4,0,0"
                Command="{Binding RunContainerCommand}" />
      </StackPanel>

      <!-- No results (search filter matched nothing) -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="10"
                  MinHeight="200"
                  MaxWidth="360"
                  IsVisible="{Binding HasNoResults}">
        <PathIcon Data="{StaticResource SearchRegular}"
                  Width="40" Height="40"
                  Foreground="{DynamicResource TextDimBrush}" />
        <TextBlock Text="No matching containers"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <TextBlock Text="Try a different search term."
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Foreground="{DynamicResource TextDimBrush}" />
      </StackPanel>

      <!-- Error state -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="10"
                  MinHeight="200"
                  MaxWidth="420"
                  IsVisible="{Binding HasError}">
        <PathIcon Data="{StaticResource WarningRegular}"
                  Width="40" Height="40"
                  Foreground="{DynamicResource TextDimBrush}" />
        <TextBlock Text="Couldn't load containers"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <SelectableTextBlock Text="{Binding ErrorMessage}"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             FontSize="13"
                             Foreground="{DynamicResource TextDimBrush}" />
        <Button Content="Retry"
                HorizontalAlignment="Center"
                Margin="0,4,0,0"
                Command="{Binding RefreshCommand}" />
      </StackPanel>
    </Grid>
    </Border>
  </Grid>

</UserControl>
