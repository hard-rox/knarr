<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Knarr.App.Features.Containers"
             xmlns:models="using:Knarr.App.Models"
             xmlns:controls="using:Knarr.App.Controls"
             x:Class="Knarr.App.Features.Containers.ContainersView"
             x:DataType="vm:ContainersViewModel">

  <Design.DataContext>
    <vm:ContainersViewModel />
  </Design.DataContext>

  <UserControl.Resources>
    <!-- Remove the vertical separator lines drawn between header cells. -->
    <SolidColorBrush x:Key="TableViewColumnHeaderSeparatorBackground" Color="Transparent" />

    <!-- Align cells with headers: rows wrap cells in a Border padded with TableViewRowPadding
       (default 6,9,6,12); the 6px left inset offsets cells right of the headers. Zero the
       horizontal part (keep vertical for row height) so both rely only on TableViewCellPadding (6,0). -->
  <Thickness x:Key="TableViewRowPadding">0,9,0,12</Thickness>

    <!-- Compact TableView theme: keeps the headers presenter but with a fixed-height, tinted header row. -->
    <ControlTheme x:Key="HeaderlessTableView"
                  TargetType="TableView"
                  BasedOn="{StaticResource {x:Type TableView}}">
      <Setter Property="Template">
        <ControlTemplate>
          <Border ClipToBounds="{TemplateBinding ClipToBounds}"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <DockPanel>
              <TableViewColumnHeadersPresenter DockPanel.Dock="Top"
                                               Height="35"
                                               Background="{DynamicResource StripBrush}"
                                               ClipToBounds="True" />
              <ScrollViewer Name="PART_ScrollViewer"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto">
                <ItemsPresenter Name="PART_ItemsPresenter"
                                ItemsPanel="{TemplateBinding ItemsPanel}" />
              </ScrollViewer>
            </DockPanel>
          </Border>
        </ControlTemplate>
      </Setter>
    </ControlTheme>
  </UserControl.Resources>

  <UserControl.Styles>
    <!-- Minimal icon-button used for copy + row actions -->
    <Style Selector="Button.icon">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="5" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}" />
    </Style>
    <Style Selector="Button.icon:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource HoverBrush}" />
    </Style>
    <Style Selector="Button.icon PathIcon">
      <Setter Property="Width" Value="14" />
      <Setter Property="Height" Value="14" />
    </Style>

    <!-- Header cells: no border, transparent so the tinted header row shows through as one strip. -->
    <!-- <Style Selector="TableViewColumnHeader">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style> -->

    <!-- Disable row selection highlight (the IsSelected checkbox still drives selection). -->
    <Style Selector="TableViewRow:pointerover /template/ Border#Border">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TableViewRow:pressed /template/ Border#Border">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TableViewRow:selected /template/ Border#Border">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TableViewRow:selected:pointerover /template/ Border#Border">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TableViewRow:selected:pressed /template/ Border#Border">
      <Setter Property="Background" Value="Transparent" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*" Margin="24" RowSpacing="16">

    <!-- Merged toolbar + bulk-action bar -->
    <Border Grid.Row="0"
            Classes="glass-card"
            Background="{DynamicResource GlassFillBrush}"
            BorderBrush="{DynamicResource StrokeBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Padding="14,10">
      <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">

        <!-- Title / selection count -->
        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   Text="Containers"
                   IsVisible="{Binding !HasSelection}" />
        <TextBlock Grid.Column="0"
                   VerticalAlignment="Center"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}"
                   IsVisible="{Binding HasSelection}"
                   Text="{Binding SelectedCount, StringFormat='{}{0} selected'}" />

        <!-- Search -->
        <TextBox Grid.Column="1"
                 MaxWidth="280"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center"
                 PlaceholderText="Search containers&#x2026;"
                 Text="{Binding SearchText}" />

        <!-- Default toolbar OR bulk actions when rows are selected -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="8"
                    IsVisible="{Binding !HasSelection}">
          <Button Content="Refresh" Command="{Binding RefreshCommand}" />
          <Button Content="Run container" Command="{Binding RunContainerCommand}" />
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="2"
                    IsVisible="{Binding HasSelection}">
          <Button Classes="icon"
                  ToolTip.Tip="Start selected"
                  Command="{Binding StartSelectedCommand}">
            <PathIcon Data="{StaticResource PlayRegular}" />
          </Button>
          <Button Classes="icon"
                  ToolTip.Tip="Stop selected"
                  Command="{Binding StopSelectedCommand}">
            <PathIcon Data="{StaticResource StopRegular}" />
          </Button>
          <Button Classes="icon"
                  ToolTip.Tip="Delete selected"
                  Command="{Binding DeleteSelectedCommand}">
            <PathIcon Data="{StaticResource DeleteRegular}" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Glass panel hosting the table -->
    <Border Grid.Row="1"
            VerticalAlignment="Top"
            Classes="glass-card"
            Background="{DynamicResource GlassFillBrush}"
            BorderBrush="{DynamicResource StrokeBrush}"
            BorderThickness="1"
            CornerRadius="16"
            ClipToBounds="True">
      <TableView ItemsSource="{Binding Containers}"
                 Theme="{StaticResource HeaderlessTableView}"
                 Background="Transparent"
                 BorderThickness="0"
                 CanUserResizeColumns="False">
        <TableView.Columns>

          <!-- Select -->
          <TableViewColumn Width="48" HorizontalContentAlignment="Center">
            <TableViewColumn.Header>
              <CheckBox IsThreeState="True" HorizontalContentAlignment="Center"
                        IsChecked="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).AllSelected, Mode=TwoWay}" />
            </TableViewColumn.Header>
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" />
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Name + Container ID (selectable text) -->
          <TableViewColumn Header="Name" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <SelectableTextBlock Text="{Binding Name}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}" />
                  <SelectableTextBlock Text="{Binding ShortId}"
                                       FontFamily="Cascadia Code,Consolas,monospace"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextDimBrush}" />
                </StackPanel>
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Image (selectable text) -->
          <TableViewColumn Header="Image" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <SelectableTextBlock Text="{Binding Image}"
                                     VerticalAlignment="Center"
                                     FontFamily="Cascadia Code,Consolas,monospace"
                                     Foreground="{DynamicResource TextDimBrush}" />
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Status + Uptime -->
          <TableViewColumn Header="Status" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <controls:Pill Text="{Binding StatusText}" Status="{Binding PillStatus}" />
                  <TextBlock Text="{Binding Uptime}"
                             FontSize="11"
                             Foreground="{DynamicResource TextDimBrush}" />
                </StackPanel>
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Ports -->
          <TableViewColumn Header="Ports" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <TextBlock Text="{Binding Ports}"
                           VerticalAlignment="Center"
                           FontFamily="Cascadia Code,Consolas,monospace"
                           Foreground="{DynamicResource TextDimBrush}" />
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Actions (fixed width so it never shrinks) -->
          <TableViewColumn Header="Actions" Width="120" HorizontalContentAlignment="Left">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ContainerItem">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                  <Button Classes="icon"
                          ToolTip.Tip="Logs"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).LogsCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource TextBulletListRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Exec"
                          IsVisible="{Binding IsRunning}"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).ExecCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource CodeRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Stop"
                          IsVisible="{Binding IsRunning}"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).StopCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource StopRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Start"
                          IsVisible="{Binding !IsRunning}"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).StartCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource PlayRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Inspect"
                          IsVisible="{Binding !IsRunning}"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).InspectCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource InfoRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Remove"
                          Command="{Binding $parent[TableView].((vm:ContainersViewModel)DataContext).RemoveCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource DeleteRegular}" />
                  </Button>
                </StackPanel>
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>
        </TableView.Columns>
      </TableView>
    </Border>
  </Grid>

</UserControl>
