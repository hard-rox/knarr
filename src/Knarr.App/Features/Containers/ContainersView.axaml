<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Knarr.App.Features.Containers"
             xmlns:models="using:Knarr.App.Models"
             xmlns:controls="using:Knarr.App.Controls"
             xmlns:conv="using:Knarr.App.Converters"
             x:Class="Knarr.App.Features.Containers.ContainersView"
             x:DataType="vm:ContainersViewModel">

    <Design.DataContext>
        <vm:ContainersViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- Primary toolbar button -->
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource Accent2Brush}"/>
        </Style>

        <!-- Secondary / ghost toolbar button -->
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="{DynamicResource GlassFillBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource StrokeBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
        </Style>

        <!-- Small row action button -->
        <Style Selector="Button.action">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="7"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
        </Style>
        <Style Selector="Button.action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
        </Style>
        <Style Selector="Button.action PathIcon">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
        </Style>

        <!-- Column header cell -->
        <Style Selector="TextBlock.colhead">
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Monospace cell (ids, ports, resources) -->
        <Style Selector="TextBlock.mono">
            <Setter Property="FontFamily" Value="Cascadia Code,Consolas,monospace"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" Margin="24">

        <!-- Toolbar -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto,Auto"
              Margin="0,0,0,16">
            <TextBlock Grid.Column="0"
                       Text="Containers"
                       FontSize="24"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource TextBrush}"/>

            <!-- Search box -->
            <Border Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="260"
                    Margin="0,0,12,0"
                    Background="{DynamicResource GlassFillBrush}"
                    BorderBrush="{DynamicResource StrokeBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="10,0">
                <Grid ColumnDefinitions="Auto,*">
                    <PathIcon Grid.Column="0"
                              Width="15" Height="15"
                              Foreground="{DynamicResource TextDimBrush}"
                              Data="{StaticResource search_regular}"/>
                    <TextBox Grid.Column="1"
                             Margin="8,0,0,0"
                             Background="Transparent"
                             BorderThickness="0"
                             PlaceholderText="Search containers&#x2026;"
                             Text="{Binding SearchText}"/>
                </Grid>
            </Border>

            <Button Grid.Column="2"
                    Classes="ghost"
                    Margin="0,0,10,0"
                    Command="{Binding RefreshCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7">
                    <PathIcon Width="15" Height="15" Data="{StaticResource arrow_clockwise_regular}"/>
                    <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="3"
                    Classes="primary"
                    Command="{Binding RunContainerCommand}">
                <StackPanel Orientation="Horizontal" Spacing="7">
                    <PathIcon Width="15" Height="15" Data="{StaticResource play_regular}"/>
                    <TextBlock Text="Run container" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <!-- Container table (glass card) -->
        <Border Grid.Row="1"
                Background="{DynamicResource GlassFillBrush}"
                BorderBrush="{DynamicResource StrokeBrush}"
                BorderThickness="1"
                CornerRadius="16">
            <DockPanel>
                <!-- Header row -->
                <Border DockPanel.Dock="Top"
                        BorderBrush="{DynamicResource StrokeBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,12">
                    <Grid ColumnDefinitions="26,2*,1.6*,120,1.3*,1.3*,90,210">
                        <TextBlock Grid.Column="1" Classes="colhead" Text="NAME"/>
                        <TextBlock Grid.Column="2" Classes="colhead" Text="IMAGE"/>
                        <TextBlock Grid.Column="3" Classes="colhead" Text="STATUS"/>
                        <TextBlock Grid.Column="4" Classes="colhead" Text="PORTS"/>
                        <TextBlock Grid.Column="5" Classes="colhead" Text="CPU / MEM"/>
                        <TextBlock Grid.Column="6" Classes="colhead" Text="UPTIME"/>
                        <TextBlock Grid.Column="7" Classes="colhead" Text="ACTIONS" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Rows -->
                <ScrollViewer>
                    <ItemsControl ItemsSource="{Binding Containers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:ContainerItem">
                                <Border BorderBrush="{DynamicResource StrokeBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,12">
                                    <Grid ColumnDefinitions="26,2*,1.6*,120,1.3*,1.3*,90,210">
                                        <CheckBox Grid.Column="0" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Classes="mono"
                                                       FontSize="11"
                                                       Text="{Binding ShortId}"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Classes="mono"
                                                   Text="{Binding Image}"/>

                                        <controls:Pill Grid.Column="3"
                                                       Text="{Binding StatusText}"
                                                       Status="{Binding Status, Converter={x:Static conv:ContainerStatusToPillStatusConverter.Instance}}"/>

                                        <TextBlock Grid.Column="4"
                                                   Classes="mono"
                                                   Text="{Binding Ports}"/>

                                        <TextBlock Grid.Column="5"
                                                   Classes="mono"
                                                   Text="{Binding ResourceUsage}"/>

                                        <TextBlock Grid.Column="6"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextDimBrush}"
                                                   FontSize="12"
                                                   Text="{Binding Uptime}"/>

                                        <StackPanel Grid.Column="7"
                                                    Orientation="Horizontal"
                                                    Spacing="2"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <Button Classes="action"
                                                    ToolTip.Tip="Logs"
                                                    Command="{Binding $parent[ItemsControl].((vm:ContainersViewModel)DataContext).LogsCommand}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Data="{StaticResource text_bullet_list_regular}"/>
                                            </Button>
                                            <Button Classes="action"
                                                    ToolTip.Tip="Exec"
                                                    IsVisible="{Binding IsRunning}"
                                                    Command="{Binding $parent[ItemsControl].((vm:ContainersViewModel)DataContext).ExecCommand}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Data="{StaticResource code_regular}"/>
                                            </Button>
                                            <Button Classes="action"
                                                    ToolTip.Tip="Stop"
                                                    IsVisible="{Binding IsRunning}"
                                                    Command="{Binding $parent[ItemsControl].((vm:ContainersViewModel)DataContext).StopCommand}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Data="{StaticResource stop_regular}"/>
                                            </Button>
                                            <Button Classes="action"
                                                    ToolTip.Tip="Start"
                                                    IsVisible="{Binding !IsRunning}"
                                                    Command="{Binding $parent[ItemsControl].((vm:ContainersViewModel)DataContext).StartCommand}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Data="{StaticResource play_regular}"/>
                                            </Button>
                                            <Button Classes="action"
                                                    ToolTip.Tip="Inspect"
                                                    IsVisible="{Binding !IsRunning}"
                                                    Command="{Binding $parent[ItemsControl].((vm:ContainersViewModel)DataContext).InspectCommand}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Data="{StaticResource info_regular}"/>
                                            </Button>
                                            <Button Classes="action"
                                                    ToolTip.Tip="Remove"
                                                    Command="{Binding $parent[ItemsControl].((vm:ContainersViewModel)DataContext).RemoveCommand}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Data="{StaticResource delete_regular}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>

</UserControl>
