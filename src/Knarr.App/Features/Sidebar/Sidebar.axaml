<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Knarr.App.Features.Sidebar"
             xmlns:models="using:Knarr.App.Models"
             xmlns:conv="using:Knarr.App.Converters"
             xmlns:aconv="using:Avalonia.Data.Converters"
             x:Class="Knarr.App.Features.Sidebar.Sidebar"
             x:DataType="vm:SidebarViewModel">

    <Design.DataContext>
        <vm:SidebarViewModel/>
    </Design.DataContext>

    <UserControl.Styles>
        <!-- Collapsible sidebar: animates between the icon rail and the full panel -->
        <Style Selector="Border.sidebar">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Width" Duration="0:0:0.18" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.sidebar.expanded">
            <Setter Property="Width" Value="240"/>
        </Style>

        <!-- Navigation icons -->
        <Style Selector="PathIcon.nav-icon">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Foreground" Value="{Binding $parent[ListBoxItem].Foreground}"/>
        </Style>

        <!-- Sidebar navigation list -->
        <Style Selector="ListBox.nav">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem">
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextDimBrush}"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource HoverBrush}"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GlassStrongBrush}"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:selected:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource GlassStrongBrush}"/>
        </Style>
        <Style Selector="ListBox.nav ListBoxItem:selected">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
    </UserControl.Styles>

    <Border Classes="sidebar"
            Classes.expanded="{Binding IsSidebarExpanded}"
            Background="{DynamicResource SidebarBrush}"
            BorderBrush="{DynamicResource StrokeBrush}"
            BorderThickness="0,0,1,0">
        <DockPanel Margin="12,16">
            <!-- Brand: clicking the logo collapses / expands the sidebar -->
            <Grid DockPanel.Dock="Top"
                  ColumnDefinitions="Auto,*"
                  Margin="6,0,6,20">
                <Button Grid.Column="0"
                        Command="{Binding ToggleSidebarCommand}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0"
                        CornerRadius="11"
                        ToolTip.Tip="Toggle sidebar">
                    <Border Width="36" Height="36" CornerRadius="11"
                            Background="White" Padding="4">
                        <Image Source="avares://Knarr.App/Assets/knarr-logo.png"
                               Stretch="Uniform"/>
                    </Border>
                </Button>
                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0"
                            IsVisible="{Binding IsSidebarExpanded}">
                    <TextBlock Text="knǫrr"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="v1.0.0"
                               FontSize="10"
                               Foreground="{DynamicResource TextDimBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Platform + CLI version footer -->
            <Border DockPanel.Dock="Bottom"
                    Margin="4,8,4,0"
                    Padding="12"
                    CornerRadius="14"
                    Background="{DynamicResource GlassFillBrush}"
                    BorderBrush="{DynamicResource StrokeBrush}"
                    BorderThickness="1"
                    IsVisible="{Binding IsSidebarExpanded}">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding PlatformName}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"/>
                    <TextBlock Text="{Binding CliDisplay}"
                               FontSize="12"
                               Foreground="{DynamicResource TextDimBrush}"/>
                </StackPanel>
            </Border>

            <!-- Navigation -->
            <ListBox Classes="nav"
                     ItemsSource="{Binding NavigationItems}"
                     SelectedItem="{Binding SelectedItem}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="models:NavigationItem">
                        <Grid ColumnDefinitions="18,*,Auto">
                            <PathIcon Grid.Column="0"
                                      Classes="nav-icon"
                                      HorizontalAlignment="Center"
                                      Data="{Binding Icon, Converter={x:Static conv:IconKeyToGeometryConverter.Instance}}"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Title}"
                                       Margin="11,0,0,0"
                                       VerticalAlignment="Center"
                                       IsVisible="{Binding $parent[ListBox].((vm:SidebarViewModel)DataContext).IsSidebarExpanded}"/>
                            <Border Grid.Column="2"
                                    Background="{DynamicResource GlassStrongBrush}"
                                    CornerRadius="10"
                                    Padding="8,1"
                                    VerticalAlignment="Center">
                                <Border.IsVisible>
                                    <MultiBinding Converter="{x:Static aconv:BoolConverters.And}">
                                        <Binding Path="HasBadge"/>
                                        <Binding Path="$parent[ListBox].((vm:SidebarViewModel)DataContext).IsSidebarExpanded"/>
                                    </MultiBinding>
                                </Border.IsVisible>
                                <TextBlock Text="{Binding Badge}"
                                           FontSize="11"
                                           Foreground="{DynamicResource TextDimBrush}"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
</UserControl>
