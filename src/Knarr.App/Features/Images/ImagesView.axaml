<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Knarr.App.Features.Images"
             xmlns:models="using:Knarr.App.Models"
             x:Class="Knarr.App.Features.Images.ImagesView"
             x:DataType="vm:ImagesViewModel">

  <Design.DataContext>
    <vm:ImagesViewModel />
  </Design.DataContext>

  <Grid RowDefinitions="Auto,*" Margin="24" RowSpacing="16">

    <!-- Action bar: search (always) + toolbar / bulk actions -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">

        <!-- Search -->
        <TextBox Grid.Column="0"
                 Classes="search"
                 Width="280"
                 VerticalAlignment="Center"
                 PlaceholderText="Search images&#x2026;"
                 Text="{Binding SearchText}">
          <TextBox.InnerLeftContent>
            <PathIcon Data="{StaticResource SearchRegular}"
                      Width="14" Height="14"
                      Margin="6,0,2,0"
                      Foreground="{DynamicResource TextDimBrush}" />
          </TextBox.InnerLeftContent>
        </TextBox>

        <!-- Selection count -->
        <TextBlock Grid.Column="1"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextDimBrush}"
                   IsVisible="{Binding HasSelection}"
                   Text="{Binding SelectedCount, StringFormat='{}{0} selected'}" />

        <!-- Default toolbar OR bulk actions when rows are selected -->
        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="2"
                    IsVisible="{Binding !HasSelection}">
          <Button Classes="icon"
                  ToolTip.Tip="Build"
                  Command="{Binding BuildCommand}">
            <PathIcon Data="{StaticResource CubeRegular}" />
          </Button>
          <Button Classes="icon"
                  ToolTip.Tip="Pull"
                  Command="{Binding PullCommand}">
            <PathIcon Data="{StaticResource ArrowDownloadRegular}" />
          </Button>
          <Button Classes="icon"
                  ToolTip.Tip="Import"
                  Command="{Binding ImportCommand}">
            <PathIcon Data="{StaticResource ArrowImportRegular}" />
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="2"
                    IsVisible="{Binding HasSelection}">
          <Button Classes="icon"
                  ToolTip.Tip="Delete selected"
                  Command="{Binding DeleteSelectedCommand}">
            <PathIcon Data="{StaticResource DeleteRegular}" />
          </Button>
        </StackPanel>
      </Grid>

    <!-- Glass panel hosting the table -->
    <Border Grid.Row="1"
            VerticalAlignment="Top"
            Classes="glass-panel"
            CornerRadius="16"
            ClipToBounds="True">
      <Grid>
        <TableView ItemsSource="{Binding Images}"
                 Theme="{StaticResource GlassTableTheme}"
                 Background="Transparent"
                 BorderThickness="0"
                 IsVisible="{Binding HasItems}"
                 CanUserResizeColumns="False">
        <TableView.Columns>

          <!-- Select -->
          <TableViewColumn Width="48" HorizontalContentAlignment="Center">
            <TableViewColumn.Header>
              <CheckBox IsThreeState="True" HorizontalContentAlignment="Center"
                        IsChecked="{Binding $parent[TableView].((vm:ImagesViewModel)DataContext).AllSelected, Mode=TwoWay}" />
            </TableViewColumn.Header>
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ImageItem">
                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" />
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Image (selectable text) -->
          <TableViewColumn Header="Image" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ImageItem">
                <StackPanel VerticalAlignment="Center" Spacing="2">
                  <StackPanel Orientation="Horizontal" Spacing="6">
                    <SelectableTextBlock Text="{Binding RepoTag}"
                                         VerticalAlignment="Center"
                                         FontWeight="SemiBold"
                                         Foreground="{DynamicResource TextBrush}" />
                    <Button Classes="icon"
                            ToolTip.Tip="Copy name"
                            Click="OnCopyImageName">
                      <PathIcon Data="{StaticResource CopyRegular}" />
                    </Button>
                  </StackPanel>
                  <SelectableTextBlock Text="{Binding Id}"
                                       FontFamily="Cascadia Code,Consolas,monospace"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextDimBrush}" />
                </StackPanel>
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Created -->
          <TableViewColumn Header="Created" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ImageItem">
                <TextBlock Text="{Binding Created}"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextDimBrush}" />
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Size -->
          <TableViewColumn Header="Size" Width="Auto">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ImageItem">
                <TextBlock Text="{Binding Size}"
                           VerticalAlignment="Center"
                           FontFamily="Cascadia Code,Consolas,monospace"
                           Foreground="{DynamicResource TextDimBrush}" />
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>

          <!-- Actions (fixed width so it never shrinks) -->
          <TableViewColumn Header="Actions" Width="120" HorizontalContentAlignment="Left">
            <TableViewColumn.CellTemplate>
              <DataTemplate x:DataType="models:ImageItem">
                <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                  <Button Classes="icon"
                          ToolTip.Tip="Run"
                          Command="{Binding $parent[TableView].((vm:ImagesViewModel)DataContext).RunCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource PlayRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Inspect"
                          Command="{Binding $parent[TableView].((vm:ImagesViewModel)DataContext).InspectCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource InfoRegular}" />
                  </Button>
                  <Button Classes="icon"
                          ToolTip.Tip="Remove"
                          Command="{Binding $parent[TableView].((vm:ImagesViewModel)DataContext).RemoveCommand}"
                          CommandParameter="{Binding}">
                    <PathIcon Data="{StaticResource DeleteRegular}" />
                  </Button>
                </StackPanel>
              </DataTemplate>
            </TableViewColumn.CellTemplate>
          </TableViewColumn>
        </TableView.Columns>
      </TableView>

      <!-- Loading state -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="14"
                  MinHeight="200"
                  IsVisible="{Binding IsLoading}">
        <ProgressBar Width="180"
                     Margin="0,12,0,0"
                     IsIndeterminate="True"
                     Foreground="{DynamicResource AccentBrush}" />
        <TextBlock Text="Loading images&#x2026;"
                   HorizontalAlignment="Center"
                   FontSize="13"
                   Foreground="{DynamicResource TextDimBrush}" />
      </StackPanel>

      <!-- Empty state (no images at all) -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="10"
                  MinHeight="200"
                  MaxWidth="360"
                  IsVisible="{Binding IsEmpty}">
        <PathIcon Data="{StaticResource CloudRegular}"
                  Margin="0,20,0,0"
                  Width="40" Height="40"
                  Foreground="{DynamicResource TextDimBrush}" />
        <TextBlock Text="No images yet"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <TextBlock Text="Pull an image from a registry to get started."
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Foreground="{DynamicResource TextDimBrush}" />
        <Button HorizontalAlignment="Center"
                Margin="0,4,0,0"
                Classes="accent"
                Command="{Binding PullCommand}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <PathIcon Data="{StaticResource ArrowDownloadRegular}" Width="14" Height="14" />
            <TextBlock Text="Pull image" />
          </StackPanel>
        </Button>
      </StackPanel>

      <!-- No results (search filter matched nothing) -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="10"
                  MinHeight="200"
                  MaxWidth="360"
                  IsVisible="{Binding HasNoResults}">
        <PathIcon Data="{StaticResource SearchRegular}"
                  Margin="0,20,0,0"
                  Width="40" Height="40"
                  Foreground="{DynamicResource TextDimBrush}" />
        <TextBlock Text="No matching images"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <TextBlock Text="Try a different search term, or pull it from a registry."
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Foreground="{DynamicResource TextDimBrush}" />
        <Button HorizontalAlignment="Center"
                Margin="0,4,0,0"
                Classes="accent"
                Command="{Binding PullCommand}"
                CommandParameter="{Binding SearchText}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <PathIcon Data="{StaticResource ArrowDownloadRegular}" Width="14" Height="14" />
            <TextBlock Text="Pull image" />
          </StackPanel>
        </Button>
      </StackPanel>

      <!-- Error state -->
      <StackPanel HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Spacing="10"
                  MinHeight="200"
                  MaxWidth="420"
                  IsVisible="{Binding HasError}">
        <PathIcon Data="{StaticResource WarningRegular}"
                  Margin="0,20,0,0"
                  Width="40" Height="40"
                  Foreground="{DynamicResource TextDimBrush}" />
        <TextBlock Text="Couldn't load images"
                   HorizontalAlignment="Center"
                   FontSize="15"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextBrush}" />
        <SelectableTextBlock Text="{Binding ErrorMessage}"
                             HorizontalAlignment="Center"
                             TextAlignment="Center"
                             TextWrapping="Wrap"
                             FontSize="13"
                             Foreground="{DynamicResource TextDimBrush}" />
        <Button Content="Retry"
                HorizontalAlignment="Center"
                Margin="0,4,0,0"
                Command="{Binding RefreshCommand}" />
      </StackPanel>
    </Grid>
    </Border>
  </Grid>

</UserControl>
