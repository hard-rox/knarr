<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Knarr.App.Features.Images"
        x:Class="Knarr.App.Features.Images.PullImageDialog"
        x:DataType="vm:PullImageDialogViewModel"
        Title="Pull image"
        Width="620" Height="220"
        MinWidth="480" MinHeight="200"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBaseBrush}">

  <Design.DataContext>
    <vm:PullImageDialogViewModel />
  </Design.DataContext>

  <Window.KeyBindings>
    <KeyBinding Gesture="Enter" Command="{Binding PullCommand}" />
    <KeyBinding Gesture="Escape" Command="{Binding CloseCommand}" />
  </Window.KeyBindings>

        <Grid Margin="20" RowDefinitions="Auto,Auto,Auto" RowSpacing="14">

    <!-- Reference input -->
                <StackPanel Grid.Row="0" Spacing="6">
      <TextBlock Text="Image reference"
                 FontWeight="SemiBold"
                 Foreground="{DynamicResource TextBrush}" />
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                                <TextBox Grid.Column="0"
                                                                 Text="{Binding ImageReference}"
                                                                 PlaceholderText="docker.io/library/alpine:3.20"
                                                                 IsEnabled="{Binding !IsRunning}"
                                                                 FontFamily="Cascadia Code,Consolas,monospace" />
                                <Button Grid.Column="1"
                                                                Content="Pull"
                                                                Classes="accent"
                                                                Command="{Binding PullCommand}"
                                                                IsVisible="{Binding !IsRunning}" />
                                <Button Grid.Column="1"
                                                                Content="Cancel"
                                                                Command="{Binding CancelCommand}"
                                                                IsVisible="{Binding IsRunning}" />
                                <Button Grid.Column="2"
                                                                Content="Close"
                                                                Command="{Binding CloseCommand}" />
                        </Grid>
    </StackPanel>

    <!-- Status line -->
    <TextBlock Grid.Row="1"
               Text="{Binding StatusMessage}"
               IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
               FontSize="12"
               Foreground="{DynamicResource TextDimBrush}" />

    <!-- In-flight progress -->
    <ProgressBar Grid.Row="2"
                 IsIndeterminate="True"
                 IsVisible="{Binding IsRunning}"
                 Foreground="{DynamicResource AccentBrush}" />
  </Grid>
</Window>
