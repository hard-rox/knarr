<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Knarr.App.Features.Shell"
        xmlns:svc="using:Knarr.App.Services"
        xmlns:sidebar="using:Knarr.App.Features.Sidebar"
        xmlns:aconv="using:Avalonia.Data.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="Knarr.App.Features.Shell.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/knarr.ico"
        Title="Knarr"
        Width="1100" Height="720"
        MinWidth="880" MinHeight="560"
        TransparencyLevelHint="Mica,AcrylicBlur,Blur"
        Background="Transparent">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <NativeMenu.Menu>
        <NativeMenu>
            <!-- <NativeMenuItem Header="File">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Refresh"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="Quit"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem> -->
            <NativeMenuItem Header="View">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Theme">
                            <NativeMenuItem.Menu>
                                <NativeMenu>
                                    <NativeMenuItem Header="System"
                                                    Command="{Binding SetThemeCommand}"
                                                    CommandParameter="{x:Static svc:AppTheme.System}"/>
                                    <NativeMenuItem Header="Light"
                                                    Command="{Binding SetThemeCommand}"
                                                    CommandParameter="{x:Static svc:AppTheme.Light}"/>
                                    <NativeMenuItem Header="Dark"
                                                    Command="{Binding SetThemeCommand}"
                                                    CommandParameter="{x:Static svc:AppTheme.Dark}"/>
                                </NativeMenu>
                            </NativeMenuItem.Menu>
                        </NativeMenuItem>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
            <!-- <NativeMenuItem Header="Help">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="About Knarr"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem> -->
        </NativeMenu>
    </NativeMenu.Menu>

    <Panel Background="{DynamicResource BackgroundBaseBrush}">
        <DockPanel>
            <!-- Menu bar: in-window on Windows/Linux, system menu bar on macOS -->
            <NativeMenuBar DockPanel.Dock="Top"/>

            <!-- Body: sidebar + resizable content area -->
            <Grid ColumnDefinitions="Auto,4,*">
                <!-- LEFT SIDEBAR -->
                <sidebar:Sidebar Grid.Column="0" DataContext="{Binding Sidebar}"/>

                <GridSplitter Grid.Column="1"
                              ResizeDirection="Columns"
                              Background="Transparent"/>

                <!-- CONTENT AREA: swaps page views with a fade when the sidebar selection changes -->
                <Border Grid.Column="2" Background="Transparent">
                    <Panel>
                        <TransitioningContentControl Content="{Binding CurrentPage}">
                            <TransitioningContentControl.PageTransition>
                                <CrossFade Duration="0:0:0.2"/>
                            </TransitioningContentControl.PageTransition>
                        </TransitioningContentControl>

                        <!-- Fallback for nav items that do not yet have a page -->
                        <TextBlock Text="{Binding Sidebar.SelectedItem.Title}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextDimBrush}"
                                   IsVisible="{Binding CurrentPage, Converter={x:Static aconv:ObjectConverters.IsNull}}"/>
                    </Panel>
                </Border>
            </Grid>
        </DockPanel>
    </Panel>

</Window>
